# ─────────────────────────────────────────────────────────────────────────
# Database — Neon Postgres
# ─────────────────────────────────────────────────────────────────────────

# Pooled connection (-pooler suffix) — used by long-running workers for
# high-concurrency request handling. Neon's pooler runs in transaction mode.
NEON_DATABASE_URL_POOLED=postgresql://user:pass@host-pooler.region.neon.tech/db?sslmode=require

# Direct connection — used by `pnpm db:migrate`, the rollup cron, and the
# generator (which needs advisory locks, which the pooler doesn't support).
NEON_DATABASE_URL_DIRECT=postgresql://user:pass@host.region.neon.tech/db?sslmode=require

# Fallbacks: when the NEON_* vars are unset, the code accepts DATABASE_URL
# (pooled) / DATABASE_URL_UNPOOLED (direct) — the names the Vercel-Neon
# integration provides.


# ─────────────────────────────────────────────────────────────────────────
# Benchmarked providers — these appear on the leaderboard.
# Each value is a FULL JSON-RPC URL (with API key embedded if applicable).
# Any provider whose env is unset is silently skipped at runtime.
# ─────────────────────────────────────────────────────────────────────────

# Helius RPC endpoint (benchmarked as "helius"). Full URL, key included.
# e.g. https://beta.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_URL=

# e.g. https://api.triton.one/?api-key=YOUR_KEY  (or your Triton One endpoint)
TRITON_URL=

# e.g. https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_URL=

# e.g. https://your-endpoint.solana-mainnet.quiknode.pro/YOUR_KEY/
QUICKNODE_URL=


# ─────────────────────────────────────────────────────────────────────────
# Utility endpoint — the generator's chain-observation RPC. Used for challenge
# derivation/preflight, slot polling, and honeypot ground-truth seeding. It
# never votes on correctness, so it needs no independence from the panel
# (reusing a panel member's endpoint here is fine). NEVER on the leaderboard;
# workers don't see this URL.
# ─────────────────────────────────────────────────────────────────────────

UTILITY_RPC_URL=


# ─────────────────────────────────────────────────────────────────────────
# Generator
# ─────────────────────────────────────────────────────────────────────────

# HMAC secret for the commit-reveal protocol — `seed = HMAC(secret, slot, ts)`.
# Generate with: `openssl rand -hex 32`
GENERATOR_SECRET=


# ─────────────────────────────────────────────────────────────────────────
# Worker identity — only relevant for the worker process. Generator and
# rollup-cron ignore these.
# ─────────────────────────────────────────────────────────────────────────

# Which cloud/vantage this worker represents on the dashboard (e.g. aws, gcp,
# cloudflare, tsw). Defaults to "aws" — set it explicitly for non-AWS vantages
# or a local run will masquerade as the AWS vantage.
WORKER_PROVIDER=aws

# Tagged on every sample row. The leaderboard groups by region.
WORKER_REGION=us-east-2

# Tagged on every sample row. Distinguishes egress paths (different EIPs / clouds)
# so we can detect provider allowlisting. One worker process per egress.
#   aws-nat-a      = primary AWS NAT gateway in AZ-A
#   aws-nat-b      = primary AWS NAT gateway in AZ-B
#   cf-containers  = Cloudflare Containers vantage
# GCP and bare-metal values are deployment-defined (Terraform `egress_path`
# var / deploy-tsw.sh argument).
WORKER_EGRESS_PATH=aws-nat-a

# Optional. Defaults to `${hostname}-${pid}`. Used as the worker_heartbeat key.
WORKER_ID=

# Port for the worker's health/status HTTP server. Defaults to 8080.
PORT=


# ─────────────────────────────────────────────────────────────────────────
# Web / dashboard
# ─────────────────────────────────────────────────────────────────────────

# Public base URL of your dashboard deployment (no trailing slash). Used for
# OG/share cards and the benchmark CLI's "View on web" link. Optional — the
# web app falls back to relative URLs when unset.
NEXT_PUBLIC_SITE_URL=

# Optional. Bearer token guarding the /api/prewarm cron route. Only needed if
# you run the Vercel cron that pre-warms caches; the request must send
# `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=


# ─────────────────────────────────────────────────────────────────────────
# Debug / development toggles — leave unset in production.
# ─────────────────────────────────────────────────────────────────────────

# "1" relaxes leaderboard eligibility thresholds (shorter window, lower
# sample floor) so a fresh deploy ranks within the first hour. Read by the
# rollup job and the web leaderboard — set it on both or neither.
TEST_MODE=

# "1" enables verbose per-challenge tracing in the worker (always on for
# the Cloudflare vantage, where container stdout is the only debug surface).
WORKER_TRACE=

# Note: METHODOLOGY_VERSION is NOT an env var — it's a code constant in
# packages/shared/src/timing.ts, bumped only when scoring semantics change.
